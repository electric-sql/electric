: in progress txids"}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Row MVCC metadata:"}]},{"type":"bulletList","attrs":{"dir":"auto"},"content":[{"type":"listItem","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"xmin: inserting txid (last insert/update)"}]}]},{"type":"listItem","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"xmax: deleting txid"}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"}},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"pg_current_wal_insert_lsn() in READ COMMITED:"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"The safe \"coverage\" bound - the snapshot we are querying is at or previous that that LSN."}]}]}},"parentId":"page:page","index":"a1dP4dZV","typeName":"shape"},{"x":1575.9413083148725,"y":1346.4916554657102,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:5CCPSYhFEsrZ_YqWbkJCw","type":"geo","props":{"w":491,"h":109.93147207274546,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"l","font":"mono","align":"middle","verticalAlign":"middle","richText":{"type":"doc","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Shape: issue WHERE project.active = true"}]}]}},"parentId":"page:page","index":"aCXUljqG","typeName":"shape"},{"meta":{},"id":"binding:jr7r9l9WiRZj8gbTq0FT8","type":"arrow","fromId":"shape:swWBLTzD8is-DJr3jDdxO","toId":"shape:XvWNkWFcPVC0YU0ocWRLx","props":{"isPrecise":true,"isExact":false,"normalizedAnchor":{"x":0.4330883163308338,"y":0.4047619047619045},"snap":"none","terminal":"end"},"typeName":"binding"},{"x":1518.639817324432,"y":-491.28794065194825,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:I_x4WjN2g1upSyMqDw5xO","type":"arrow","props":{"kind":"arc","elbowMidPoint":0.5,"dash":"draw","size":"m","fill":"none","color":"black","labelColor":"black","bend":0,"start":{"x":1.9104713401986828,"y":-30.397215454148522},"end":{"x":-52.10127269989425,"y":-142.41014537971114},"arrowheadStart":"none","arrowheadEnd":"arrow","richText":{"type":"doc","content":[{"type":"paragraph"}]},"labelPosition":0.5,"font":"mono","scale":1},"parentId":"page:page","index":"aV1uAhiV","typeName":"shape"},{"x":1810.5342805132495,"y":1190.755403362654,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:w8ui9Lj2n9-uskiTuolwM","type":"arrow","props":{"kind":"arc","elbowMidPoint":0.5,"dash":"draw","size":"l","fill":"none","color":"black","labelColor":"black","bend":0,"start":{"x":0,"y":0},"end":{"x":2,"y":0},"arrowheadStart":"none","arrowheadEnd":"arrow","richText":{"type":"doc","content":[{"type":"paragraph"}]},"labelPosition":0.5,"font":"mono","scale":1},"parentId":"page:page","index":"aGa7R0SV","typeName":"shape"},{"x":889.8794294848019,"y":950.2803082035236,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:alG7oRWi1NVlkYZNm5OT4","type":"geo","props":{"w":417.5379500797935,"h":89.31932105910573,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"l","font":"mono","align":"middle","verticalAlign":"middle","richText":{"type":"doc","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Filter: active = true"}]}]}},"parentId":"page:page","index":"aDOyKspV","typeName":"shape"},{"x":853.2568330413491,"y":725.2158296131194,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:PAMnZJJXViVmgO6qgGrIV","type":"geo","props":{"w":490.7831429666993,"h":81.79719049444975,"geo":"rectangle","dash":"draw","growY":0,"url":"","scale":1,"color":"black","labelColor":"black","fill":"none","size":"l","font":"mono","align":"middle","verticalAlign":"middle","richText":{"type":"doc","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Input: Projects"}]}]}},"parentId":"page:page","index":"a88lxGzl","typeName":"shape"},{"x":419.5535917513937,"y":657.4849643383977,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:dHLaXh1qESUJwNZdS3AF5","type":"arrow","props":{"kind":"arc","elbowMidPoint":0.5,"dash":"draw","size":"m","fill":"none","color":"black","labelColor":"black","bend":0,"start":{"x":0,"y":0},"end":{"x":368.6756169947005,"y":68.51493767158172},"arrowheadStart":"none","arrowheadEnd":"arrow","richText":{"type":"doc","content":[{"type":"paragraph"}]},"labelPosition":0.5,"font":"mono","scale":1},"parentId":"page:page","index":"aMzPq4Op","typeName":"shape"},{"meta":{},"id":"binding:qGcv79SKkI46Rgxa6I5Nl","type":"arrow","fromId":"shape:c0c1dLu0_dzsWOXvgfIIj","toId":"shape:opKx0-LyuGJXrBZ8N0x_R","props":{"isPrecise":true,"isExact":false,"normalizedAnchor":{"x":0.828299750498739,"y":0.19162789261460356},"snap":"none","terminal":"end"},"typeName":"binding"},{"x":-1365.5728495285753,"y":-835.647922237782,"rotation":0,"isLocked":false,"opacity":1,"meta":{},"id":"shape:opKx0-LyuGJXrBZ8N0x_R","type":"text","props":{"color":"black","size":"s","w":857.2942122289519,"font":"mono","textAlign":"start","autoSize":false,"scale":1,"richText":{"type":"doc","attrs":{"dir":"auto"},"content":[{"type":"heading","attrs":{"dir":"auto","level":2},"content":[{"type":"text","text":"A. What you’re trying to guarantee"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"You run a “side query” against Postgres to fetch extra data, and you want to splice that result into your pgoutput stream at a point that’s consistent with what the query saw."}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"In READ COMMITTED, each SQL "},{"type":"text","marks":[{"type":"bold"}],"text":"statement"},{"type":"text","text":" sees a snapshot taken at statement start. So your side-query result is consistent with "},{"type":"text","marks":[{"type":"bold"}],"text":"“all commits that happened before that statement began”"},{"type":"text","text":"."}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"So you want to emit:"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"all replication transactions that committed before the side query snapshot,"},{"type":"hardBreak","attrs":{"dir":"auto"}},{"type":"text","text":"then your query result,"},{"type":"hardBreak","attrs":{"dir":"auto"}},{"type":"text","text":"then replication transactions that committed after."}]},{"type":"heading","attrs":{"dir":"auto","level":2},"content":[{"type":"text","text":"B. Query-back: capture snapshot + barrier + rows in "},{"type":"text","marks":[{"type":"bold"}],"text":"one SQL statement"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Do "},{"type":"text","marks":[{"type":"bold"}],"text":"not"},{"type":"text","text":" do "},{"type":"text","marks":[{"type":"code"}],"text":"SELECT pg_current_snapshot(); SELECT ...; SELECT pg_current_wal_insert_lsn();"},{"type":"text","text":" as separate statements under READ COMMITTED: those would be "},{"type":"text","marks":[{"type":"bold"}],"text":"different snapshots"},{"type":"text","text":"."}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Instead, capture metadata and rows in a single statement (same statement snapshot):"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"code"}],"text":"WITH meta AS (   SELECT     pg_current_snapshot()        AS snap,     pg_current_wal_insert_lsn()  AS barrier_lsn ) SELECT   meta.snap,   meta.barrier_lsn,   q.* FROM meta JOIN LATERAL (   -- your actual lookup query   SELECT ... ) AS q ON true; "}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"This produces a “query packet”:"}]},{"type":"bulletList","attrs":{"dir":"auto"},"content":[{"type":"listItem","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"code"}],"text":"snap = (xmin, xmax, xip_list)"}]}]},{"type":"listItem","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"code"}],"text":"barrier_lsn = L_barrier"}]}]},{"type":"listItem","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"code"}],"text":"rows = …"}]}]}]},{"type":"heading","attrs":{"dir":"auto","level":3},"content":[{"type":"text","text":"Intuition"}]},{"type":"bulletList","attrs":{"dir":"auto"},"content":[{"type":"listItem","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"code"}],"text":"snap"},{"type":"text","text":" tells you which top-level transactions were "},{"type":"text","marks":[{"type":"bold"}],"text":"in-progress"},{"type":"text","text":" at snapshot time ("},{"type":"text","marks":[{"type":"code"}],"text":"xip_list"},{"type":"text","text":"), and where the “not yet started” boundary is ("},{"type":"text","marks":[{"type":"code"}],"text":"xmax"},{"type":"text","text":")."}]}]},{"type":"listItem","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"code"}],"text":"L_barrier"},{"type":"text","text":" gives you a "},{"type":"text","marks":[{"type":"bold"}],"text":"stable LSN marker"},{"type":"text","text":" at or after the moment you captured the statement’s snapshot (an upper-bound-ish marker you can use if the DB goes quiet)."}]}]}]},{"type":"heading","attrs":{"dir":"auto","level":2},"content":[{"type":"text","text":"C. Stream-side state you maintain (pgoutput)"}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"From pgoutput you get:"}]},{"type":"bulletList","attrs":{"dir":"auto"},"content":[{"type":"listItem","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"code"}],"text":"BEGIN"},{"type":"text","text":" → top-level "},{"type":"text","marks":[{"type":"code"}],"text":"xid"}]}]},{"type":"listItem","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"code"}],"text":"COMMIT"},{"type":"text","text":" → "},{"type":"text","marks":[{"type":"code"}],"text":"commit_lsn"},{"type":"text","text":" and "},{"type":"text","marks":[{"type":"code"}],"text":"end_lsn"}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"Maintain:"}]},{"type":"bulletList","attrs":{"dir":"auto"},"content":[{"type":"listItem","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"code"}],"text":"last_end_lsn_seen"},{"type":"text","text":" (monotonic, update from each COMMIT’s "},{"type":"text","marks":[{"type":"code"}],"text":"end_lsn"},{"type":"text","text":")"}]}]},{"type":"listItem","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","marks":[{"type":"code"}],"text":"last_wal_end_seen"},{"type":"text","text":" from keepalives (server “walEnd”; pgoutput keepalive messages include this)"}]}]},{"type":"listItem","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"a list of “pending query packets” (you can support multiple)"}]}]}]},{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","text":"For each pending query packet "},{"type":"text","marks":[{"type":"code"}],"text":"Q"},{"type":"text","text":":"}]},{"type":"bulletList","attrs":{"dir":"auto"},"content":[{"type":"listItem","attrs":{"dir":"auto"},"content":[{"type":"paragraph","attrs":{"dir":"auto"},"content":[{"type":"text","ma