{
  "name": "@electric-ax/agents-mobile",
  "private": true,
  "version": "0.6.1",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "coverage": "vitest run --coverage --passWithNoTests",
    "doctor": "expo-doctor",
    "export:android": "expo export --platform android --output-dir dist/android",
    "export:ios": "expo export --platform ios --output-dir dist/ios",
    "ci:check": "pnpm run typecheck && pnpm run doctor && pnpm run export:android"
  },
  "dependencies": {
    "@electric-ax/agents-runtime": "workspace:*",
    "@electric-ax/agents-server-ui": "workspace:*",
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@sentry/react-native": "~7.2.0",
    "@tanstack/db": "^0.6.5",
    "@tanstack/electric-db-collection": "^0.3.5",
    "@tanstack/react-db": "^0.1.85",
    "expo": "54.0.35",
    "expo-build-properties": "~1.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.24",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "2.28.0",
    "react-native-random-uuid": "^0.1.4",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.2",
    "react-native-webview": "13.15.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@sentry/cli": "2.55.0",
    "@types/node": "^25.9.1",
    "@types/react": "19.1.17",
    "@vitest/coverage-v8": "^4.1.0",
    "babel-preset-expo": "~54.0.10",
    "expo-doctor": "^1.19.8",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
