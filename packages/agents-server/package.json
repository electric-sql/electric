{
  "name": "@electric-ax/agents-server",
  "version": "0.4.9",
  "description": "Electric Agents entity runtime server",
  "author": "Durable Stream contributors",
  "bin": {
    "electric-agents-server": "./dist/entrypoint.js",
    "durable-streams-electric-agents-server": "./dist/entrypoint.js"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/electric-sql/electric.git",
    "directory": "packages/agents-server"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "start": "cross-env-shell DATABASE_URL=${DATABASE_URL:-postgresql://electric_agents:electric_agents@localhost:5432/electric_agents} ELECTRIC_URL=${ELECTRIC_URL:-http://localhost:3060} \"tsx --watch src/entrypoint.ts\"",
    "test": "vitest run",
    "coverage": "ELECTRIC_AGENTS_KEEP_BACKEND=1 pnpm exec vitest run --coverage $(find test -name '*.test.ts' ! -name 'conformance.test.ts' | sort) && pnpm exec vitest run test/conformance.test.ts",
    "typecheck": "tsc --noEmit",
    "stylecheck": "eslint . --quiet"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@durable-streams/client": "https://pkg.pr.new/durable-streams/durable-streams/@durable-streams/client@5d5c217",
    "@durable-streams/server": "https://pkg.pr.new/durable-streams/durable-streams/@durable-streams/server@eac712f",
    "@durable-streams/state": "https://pkg.pr.new/durable-streams/durable-streams/@durable-streams/state@5d5c217",
    "@electric-ax/agents-runtime": "workspace:*",
    "@electric-sql/client": "^1.5.19",
    "@mariozechner/pi-agent-core": "^0.70.2",
    "@opentelemetry/api": "^1.9.1",
    "@sinclair/typebox": "^0.34.48",
    "@whatwg-node/server": "^0.10.18",
    "ajv": "^8.18.0",
    "cron-parser": "^5.5.0",
    "drizzle-orm": "^0.44.0",
    "fastq": "^1.20.1",
    "itty-router": "^5.0.23",
    "lmdb": "^3.5.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.0",
    "undici": "^7.24.7"
  },
  "devDependencies": {
    "@electric-ax/agents": "workspace:*",
    "@electric-ax/agents-server-conformance-tests": "workspace:*",
    "@electric-ax/agents-server-ui": "workspace:*",
    "@types/node": "^22.19.15",
    "@vitest/coverage-v8": "^4.1.0",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.0",
    "tsdown": "^0.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.0"
  },
  "files": [
    "dist",
    "drizzle",
    "src"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
