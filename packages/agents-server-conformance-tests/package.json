{
  "name": "@electric-ax/agents-server-conformance-tests",
  "version": "0.1.1",
  "private": true,
  "description": "Conformance test suite for Electric Agents server implementations",
  "author": "Durable Stream contributors",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/electric-sql/electric.git",
    "directory": "packages/agents-server-conformance-tests"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "coverage": "true",
    "typecheck": "tsc --noEmit",
    "stylecheck": "eslint . --quiet"
  },
  "dependencies": {
    "@durable-streams/client": "npm:@electric-ax/durable-streams-client-beta@^0.3.1",
    "@electric-sql/client": "^1.5.17",
    "fast-check": "^4.6.0",
    "vitest": "^4.1.0"
  },
  "devDependencies": {
    "@electric-ax/agents-server": "workspace:*",
    "@mariozechner/pi-agent-core": "^0.70.2",
    "tsdown": "^0.9.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
