    "keytar": "^7.9.0"
  },
  "peerDependenciesMeta": {
    "keytar": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsdown": "^0.9.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
