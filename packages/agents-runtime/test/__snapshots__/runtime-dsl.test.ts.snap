exports[`A: basic entity lifecycle > A12: stateful note writes persist across wakes and can be read later > entity history 1`] = `
[
  {
    "args": {},
    "entityType": "toolful-a9",
    "operation": "insert",
    "type": "entity_created",
  },
  {
    "from": "user",
