{
  "compilerOptions": {
    "isolatedDeclarations": false,
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "target": "ES2022",
    "lib": ["ESNext", "DOM"],
    "allowJs": true,
    "skipLibCheck": true,
    "noEmit": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@electric-ax/agent-srever-conformance-tests": [
        "../agent-server-conformance-tests/src/index.ts"
      ],
      "@electric-ax/agent-srever-conformance-tests/*": [
        "../agent-server-conformance-tests/src/*"
      ]
    }
  },
  "include": ["src/**/*", "test/**/*", "*.ts"],
  "exclude": ["node_modules", "dist"]
}
