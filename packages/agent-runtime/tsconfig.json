{
  "compilerOptions": {
    "isolatedDeclarations": false,
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "target": "ES2022",
    "lib": ["ESNext", "DOM"],
    "allowJs": true,
    "skipLibCheck": true,
    "noEmit": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@electric-ax/agent-runtime": ["./src/index.ts"],
      "@electric-ax/agent-runtime/*": ["./src/*"]
    }
  },
  "include": ["src/**/*", "test/**/*", "scripts/**/*", "*.ts"],
  "exclude": ["node_modules", "dist"]
}
