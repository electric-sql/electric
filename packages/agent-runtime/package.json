{
  "name": "@electric-ax/agent-runtime",
  "version": "0.0.1",
  "description": "Electric agent runtime — behavioral stack for agent entities over durable streams",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "pnpm exec vitest --coverage",
    "typecheck": "tsc --noEmit",
    "stylecheck": "eslint . --quiet"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      },
      "require": {
        "types": "./dist/react.d.cts",
        "default": "./dist/react.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "@tanstack/react-db": ">=0.1.78",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@tanstack/react-db": {
      "optional": true
    }
  },
  "dependencies": {
    "@durable-streams/client": "npm:@electric-ax/durable-streams-client-beta@^0.3.0",
    "@durable-streams/state": "npm:@electric-ax/durable-streams-state-beta@^0.3.0",
    "@mariozechner/pi-agent-core": "^0.57.1",
    "@mariozechner/pi-ai": "^0.57.1",
    "@standard-schema/spec": "^1.1.0",
    "@tanstack/db": "^0.6.4",
    "cron-parser": "^5.5.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.0.0",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@durable-streams/server": "npm:@electric-ax/durable-streams-server-beta@^0.3.0",
    "@vitest/coverage-v8": "^3.2.4",
    "tsdown": "^0.9.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "license": "Apache-2.0"
}
