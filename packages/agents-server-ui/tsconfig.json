{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["vite/client"],
    "baseUrl": ".",
    // Only the browser-safe `client` entry is source-mapped (matches the vite
    // alias). The index resolves via package exports to dist so its node-using
    // sandbox re-exports stay behind skipLibCheck instead of leaking into the UI.
    "paths": {
      "@electric-ax/agents-runtime/client": ["../agents-runtime/src/client.ts"],
      "@electric-ax/agents-runtime/session-links": [
        "../agents-runtime/src/session-links.ts"
      ]
    }
  },
  "include": ["src", "vite.config.ts"]
}
