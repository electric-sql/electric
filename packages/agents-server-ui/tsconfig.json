{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    // "node" needed: typecheck pulls agents-runtime's node-using source via paths.
    "types": ["vite/client", "node"],
    "baseUrl": ".",
    "paths": {
      "@electric-ax/agents-runtime": ["../agents-runtime/src/index.ts"],
      "@electric-ax/agents-runtime/*": ["../agents-runtime/src/*"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
