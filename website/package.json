{
  "name": "@electric-sql/docs",
  "private": true,
  "version": "0.0.8",
  "scripts": {
    "postinstall": "node ./scripts/apply-vitepress-dts.mjs",
    "typecheck": "node ./scripts/apply-vitepress-dts.mjs && vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "api:build_docs": "redocly build-docs ./electric-api.yaml --output=./public/openapi.html",
    "api:generate": "npm run api:build_docs && npm run api:patch_version",
    "api:patch_version": "node ../scripts/patch_api_spec_version.js ./public/openapi.html",
    "api:watch": "nodemon -w ./ -x \"npm run api:generate\" -e \"electric-api.yaml\"",
    "build": "npm run build:site && npm run build:markdown-export",
    "build:site": "npm run api:generate && vitepress build . && cp ../AGENTS.md .vitepress/dist",
    "build:markdown-export": "MARKDOWN_EXPORT=1 vitepress build .",
    "dev": "vitepress dev .",
    "dev:netlify": "netlify dev",
    "preview": "vitepress preview .",
    "build-og-images": "node ./scripts/generate-og-images.mjs"
  },
  "engineManager": "^pnpm@9.15.0",
  "devDependencies": {
    "@netlify/edge-functions": "^3.0.6",
    "@redocly/cli": "^1.18.0",
    "@types/jsdom": "^28.0.1",
    "@types/turndown": "^5.0.6",
    "chart.js": "^4.4.7",
    "cheerio": "^1.2.0",
    "jsdom": "^29.0.2",
    "nodemon": "^3.1.4",
    "playwright": "^1.52.0",
    "pnpm": "^9.15.0",
    "sharp": "^0.34.5",
    "shiki": "^3.21.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "typescript": "^5.8.3",
    "vitepress": "^1.3.1",
    "vitepress-plugin-llms": "^1.7.5",
    "vitepress-plugin-tabs": "^0.5.0",
    "vitest": "^4.0.15",
    "vue-tsc": "^2.2.12",
    "vue-tweet": "^2.3.1",
    "yaml": "^2.5.0"
  },
  "dependencies": {
    "@electric-sql/pglite": "0.4.4",
    "@electric-sql/pglite-repl": "0.3.4",
    "posthog-js": "^1.236.4"
  }
}
