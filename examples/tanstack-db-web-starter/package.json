    "build": "vite build",
    "migrate": "drizzle-kit migrate",
    "migrate:generate": "drizzle-kit generate",
    "psql": "dotenvx run -- sh -c 'psql \"$DATABASE_URL\"'",
    "serve": "vite preview",
    "test": "echo 'No tests yet'",
    "lint:check": "eslint .",
    "lint": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
