# Required — Anthropic API key for agent LLM calls
ANTHROPIC_API_KEY=

# Optional — Brave Search API key for the web_search tool
# Get one at https://brave.com/search/api/
# BRAVE_SEARCH_API_KEY=

# Agents server URL (default: local dev)
AGENTS_URL=http://localhost:4437

# Backend server
PORT=4700
SERVE_URL=http://localhost:4700
